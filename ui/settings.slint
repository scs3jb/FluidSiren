// Settings window. In-out properties are seeded from Config by Rust and read
// back on Save. The `save` and `close-requested` callbacks are wired in Rust.

import { LineEdit, CheckBox, ComboBox, Button, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export component Settings inherits Window {
    in-out property <string> provider: "whisper";
    in-out property <string> whisper-model: "base.en";
    in-out property <string> language: "en";
    in-out property <bool> enhance: false;
    in-out property <string> ollama-model: "llama3.2:3b";
    in-out property <string> ollama-url: "http://localhost:11434";
    in-out property <string> ollama-keep-alive: "30m";
    in-out property <string> hotkey-key: "KEY_F12";
    // True while the capture box is focused and waiting for a keypress.
    in-out property <bool> capturing: false;
    // Live Ollama status, polled by Rust: whether the `ollama` binary is present
    // and whether the server currently answers at `ollama-url`.
    in-out property <bool> ollama-installed: false;
    in-out property <bool> ollama-running: false;

    callback save();
    callback close-requested();
    // Emitted with an evdev key name (e.g. "KEY_F12") when the user presses a key
    // in the capture box.
    callback captured(string);
    // Start / stop the local Ollama server from the manual controls.
    callback start-ollama();
    callback stop-ollama();
    // Preload the model now so the next dictation is fast.
    callback warm-up-ollama();

    title: "FluidSiren — Settings";
    // preferred-* (not fixed width/height) keeps the window user-resizable; the
    // ScrollView below lets the form scroll when the window is shrunk.
    preferred-width: 540px;
    preferred-height: 760px;
    min-width: 460px;
    min-height: 420px;
    background: #1e1e2e;

    VerticalBox {
        padding: 18px;
        spacing: 12px;

        ScrollView {
            // Takes all the space above the fixed button row; scrolls on overflow.
            vertical-stretch: 1;
            VerticalLayout {
                width: parent.width;
                spacing: 12px;

        Text {
            text: "FluidSiren Settings";
            color: #cdd6f4;
            font-size: 20px;
            font-weight: 700;
        }

        Text { text: "Speech model"; color: #a6adc8; font-size: 13px; }
        ComboBox {
            model: ["whisper", "parakeet"];
            current-value <=> root.provider;
        }
        Text {
            text: root.provider == "parakeet"
                ? "Parakeet TDT — fast, accurate English (~460 MB, downloads on first use)"
                : "Whisper — multilingual; pick a ggml model below";
            color: #6c7086;
            font-size: 11px;
            wrap: word-wrap;
        }

        Text { text: "Whisper model"; color: #a6adc8; font-size: 13px; }
        // Quick-pick presets; selecting one writes the free-text field below.
        ComboBox {
            model: ["tiny.en", "base.en", "small.en", "medium.en", "large-v3"];
            selected(value) => { root.whisper-model = value; }
        }
        LineEdit {
            text <=> root.whisper-model;
            placeholder-text: "e.g. base.en, or any whisper.cpp ggml name";
        }

        Text { text: "Language"; color: #a6adc8; font-size: 13px; }
        LineEdit {
            text <=> root.language;
            placeholder-text: "en, auto, de, fr, …";
        }

        CheckBox {
            text: "Enhance transcript with Ollama";
            checked <=> root.enhance;
        }

        Text { text: "Ollama model"; color: #a6adc8; font-size: 13px; }
        LineEdit { text <=> root.ollama-model; }

        Text { text: "Ollama URL"; color: #a6adc8; font-size: 13px; }
        LineEdit { text <=> root.ollama-url; }

        Text { text: "Keep model loaded"; color: #a6adc8; font-size: 13px; }
        ComboBox {
            model: ["5m", "30m", "1h", "-1"];
            current-value <=> root.ollama-keep-alive;
        }
        Text {
            text: "How long Ollama keeps the model in memory after use. Longer = faster repeat dictations (no cold reload); -1 keeps it loaded forever. The app preloads it on launch when enhancement is on.";
            color: #6c7086;
            font-size: 11px;
            wrap: word-wrap;
        }

        // Live status (polled by Rust every couple of seconds) + manual controls.
        // When "Enhance" is enabled the app starts the server automatically; these
        // buttons let you start/stop it by hand otherwise.
        Text {
            text: root.ollama-running
                    ? "● Ollama: running"
                    : root.ollama-installed
                        ? "● Ollama: installed, not running"
                        : "● Ollama: not installed";
            color: root.ollama-running ? #a6e3a1 : #f38ba8;
            font-size: 13px;
            font-weight: 600;
        }
        if !root.ollama-installed : Text {
            text: "Run scripts/setup-ollama.sh to install it and pull the model.";
            color: #f9e2af;
            font-size: 11px;
            wrap: word-wrap;
        }
        HorizontalBox {
            padding: 0px;
            alignment: start;
            spacing: 8px;
            Button {
                text: "Start Ollama";
                enabled: root.ollama-installed && !root.ollama-running;
                clicked => { root.start-ollama(); }
            }
            Button {
                text: "Stop Ollama";
                enabled: root.ollama-running;
                clicked => { root.stop-ollama(); }
            }
            Button {
                text: "Warm up now";
                enabled: root.ollama-running;
                clicked => { root.warm-up-ollama(); }
            }
        }

        Text {
            text: "Dictation hotkey — click the box, then press a key or combo (e.g. Ctrl+Shift+D)";
            color: #a6adc8;
            font-size: 13px;
        }
        fs := FocusScope {
            height: 42px;
            key-pressed(event) => {
                // Ignore standalone modifier presses; wait for a real key.
                if (event.text == Key.Control || event.text == Key.Shift
                    || event.text == Key.Alt || event.text == Key.Meta) {
                    return accept;
                }
                root.captured(
                    (event.modifiers.control ? "Ctrl+" : "")
                    + (event.modifiers.alt ? "Alt+" : "")
                    + (event.modifiers.shift ? "Shift+" : "")
                    + (event.modifiers.meta ? "Meta+" : "")
                    + (event.text == Key.F1 ? "F1"
                     : event.text == Key.F2 ? "F2"
                     : event.text == Key.F3 ? "F3"
                     : event.text == Key.F4 ? "F4"
                     : event.text == Key.F5 ? "F5"
                     : event.text == Key.F6 ? "F6"
                     : event.text == Key.F7 ? "F7"
                     : event.text == Key.F8 ? "F8"
                     : event.text == Key.F9 ? "F9"
                     : event.text == Key.F10 ? "F10"
                     : event.text == Key.F11 ? "F11"
                     : event.text == Key.F12 ? "F12"
                     : event.text == Key.Space ? "Space"
                     : event.text == Key.Tab ? "Tab"
                     : event.text == Key.Return ? "Return"
                     : event.text == Key.Escape ? "Escape"
                     : event.text == Key.Backspace ? "Backspace"
                     : event.text == Key.Delete ? "Delete"
                     : event.text == Key.Insert ? "Insert"
                     : event.text == Key.Home ? "Home"
                     : event.text == Key.End ? "End"
                     : event.text == Key.PageUp ? "PageUp"
                     : event.text == Key.PageDown ? "PageDown"
                     : event.text == Key.UpArrow ? "Up"
                     : event.text == Key.DownArrow ? "Down"
                     : event.text == Key.LeftArrow ? "Left"
                     : event.text == Key.RightArrow ? "Right"
                     : event.text)
                );
                root.capturing = false;
                return accept;
            }
            Rectangle {
                border-radius: 6px;
                border-width: 2px;
                border-color: root.capturing ? #f9e2af : #585b70;
                background: #313244;
                Text {
                    text: root.capturing ? "Press a key or combo…" : root.hotkey-key;
                    color: root.capturing ? #f9e2af : #cdd6f4;
                    font-size: 14px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
            TouchArea {
                clicked => {
                    fs.focus();
                    root.capturing = true;
                }
            }
        }

            } // VerticalLayout
        } // ScrollView

        HorizontalBox {
            alignment: end;
            spacing: 8px;
            Button {
                text: "Cancel";
                clicked => { root.close-requested(); }
            }
            Button {
                text: "Save";
                primary: true;
                clicked => { root.save(); }
            }
        }
    }
}
