[Desktop Entry]
Type=Application
Name=FluidSiren
GenericName=Voice Dictation
Comment=Local voice-to-text dictation (Wayland/Plasma)
Exec=fluidsiren
Icon=audio-input-microphone
Terminal=false
Categories=Utility;AudioVideo;Audio;
Keywords=dictation;speech;voice;transcription;whisper;
StartupNotify=false
# The desktop-file basename (dev.altic.FluidSiren) is the app id the
# GlobalShortcuts portal registers shortcuts under, so they belong to FluidSiren
# rather than whatever launched it.
